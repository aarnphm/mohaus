[build-system]
requires = ["mohaus>=0.1,<0.2", "mojo=={{mojo_version}}"]
build-backend = "mohaus.backend"

[project]
name = "{{project_name}}"
version = "0.1.0"
description = "Mixed Python and Mojo package scaffolded by mohaus."
readme = "README.md"
requires-python = ">=3.11"
license = "Apache-2.0"
license-files = ["LICENSE"]
authors = [{ name = "your name", email = "you@example.com" }]
classifiers = [
  "Programming Language :: Python :: 3",
  "Topic :: Software Development :: Build Tools",
]

[tool.mohaus]
mojo-src = "src"
python-src = "python"
module-name = "{{import_name}}._native"
strip = true
mojo-flags = []
mojo-include-paths = []

[tool.ruff]
indent-width = 2
line-length = 119
preview = true
target-version = "py311"

[tool.ruff.lint]
ignore = ["E111", "E114"]
select = ["E", "F", "I", "UP", "B", "ANN"]

[tool.uv.sources]
mojo = { index = "modular-nightly" }

[[tool.uv.index]]
name = "modular-nightly"
url = "https://whl.modular.com/nightly/simple/"
explicit = true
